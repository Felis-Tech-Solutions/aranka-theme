<div class="my-custom-section" style="background-color: {{ section.settings.background_color }};">
  <h2>{{ section.settings.heading }}</h2>
  <p>
    {{ section.settings.text | escape | newline_to_br }}
  </p>
  {% render 'custom-text-block'
    , title: 'Welcome to Our Store'
    , text: 'Discover our unique collection of handcrafted products.' %}


<!-- Your custom HTML here -->
</div>

{% schema %}
  {
    "name": "My Custom Section",
    "blocks": [
      {
        "type": "custom_block",
        "name": "Custom Block",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Title"
          }, {
            "type": "textarea",
            "id": "text",
            "label": "Text"
          }, {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          }
        ]
      }
    ],
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading Text",
        "default": "Sample Heading"
      }, {
        "type": "textarea",
        "id": "text",
        "label": "Text",
        "default": "Your default text goes here."
      }, {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#FFC0CB"
      }
    ]
  }
{% endschema %}