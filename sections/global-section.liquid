<!-- Global Section -->
<div class="global-section" style="background-color: {{ section.settings.background_color }}">
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.text }}</p>
</div>

{% schema %}
  {
    "name": "Global Section",
    "class": "section",
    "disabled_on": {
    "groups": ["header"]
  },
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Your Default Heading"
      },
      {
        "type": "textarea",
        "id": "text",
        "label": "Text",
        "default": "Your default text goes here."
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#ffffff"
      }
    ]
  }
{% endschema %}

{% stylesheet %}
  .global-section {
    padding: 20px;
    text-align: center;
  }
{% endstylesheet %}

{% javascript %}
  // You can add custom JavaScript here if needed.
{% endjavascript %}
